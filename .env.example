# Copy this file to `.env` on the server and fill in real values.
# `.env` is gitignored — never commit it.

# Deploy key — long random string. Used by deploy.php / update.html.
# Generate with: openssl rand -hex 32
DEPLOY_KEY=

# Anthropic API key — used by api/advisor.php to call Claude.
# Same key already in use for Optimus on fuel/alfa — copy from there or
# get a fresh one from console.anthropic.com if isolating cost is needed.
# Without this, the advisor returns a friendly "temporarily unavailable"
# message and never reaches Claude. The key is read server-side only;
# never sent to the browser.
ANTHROPIC_API_KEY=
